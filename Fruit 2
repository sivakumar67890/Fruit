-- ===========================
-- Auto Collect & Auto Store
-- ===========================
task.spawn(function()
    while true do
        if Settings.AutoCollect then
            local fruit = GetFruit()
            if fruit then
                -- Teleport to fruit
                local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = fruit.Handle.CFrame
                end
                -- Update the status text with the fruit name
                StatusText.Text = "Found: " .. fruit.Name
                -- Optional: wait for collection animation or process
                task.wait(0.2)
            else
                -- No fruit found
                StatusText.Text = "No fruit found"
            end
        end
        task.wait(0.5) -- check twice per second
    end
end)
