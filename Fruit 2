-- Utility functions
local function CreateButton(text, callback)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new("1", -4, 0, 30)
    Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.Text = text
    Btn.Font = Enum.Font.Gotham
    Btn.TextSize = 14
    Btn.BorderSizePixel = 0
    Btn.Parent = Container

    Btn.MouseButton1Click:Connect(callback)
    return Btn
end

local function CreateToggle(text, callback)
    local Tgl = Instance.new("TextButton")
    Tgl.Size = UDim2.new("1", -4, 0, 30)
    Tgl.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    Tgl.TextColor3 = Color3.fromRGB(200, 0, 0)
    Tgl.Text = text .. ": OFF"
    Tgl.Font = Enum.Font.Gotham
    Tgl.TextSize = 14
    Tgl.BorderSizePixel = 0
    Tgl.Parent = Container

    local state = false
    Tgl.MouseButton1Click:Connect(function()
        state = not state
        Tgl.Text = text .. ": " .. (state and "ON" or "OFF")
        Tgl.TextColor3 = state and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(200, 0, 0)
        callback(state)
    end)
    return {toggleButton = Tgl, state = false}
end

local function Notify(msg)
    local Notification = Instance.new("Frame")
    Notification.Size = UDim2.new(0, 250, 0, 50)
    Notification.Position = UDim2.new(1, 10, 0.8, 0)
    Notification.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
    Notification.BorderSizePixel = 1
    Notification.BorderColor3 = Color3.fromRGB(255, 0, 0)
    Notification.Parent = UI

    local Text = Instance.new("TextLabel")
    Text.Size = UDim2.new(1, 0, 1, 0)
    Text.BackgroundTransparency = 1
    Text.Text = msg
    Text.TextColor3 = Color3.fromRGB(255, 255, 255)
    Text.Font = Enum.Font.GothamSemibold
    Text.Parent = Notification

    Notification:TweenPosition(UDim2.new(1, -260, 0.8, 0), "Out", "Quart", 0.5, true)
    task.wait(3)
    Notification:TweenPosition(UDim2.new(1, 10, 0.8, 0), "In", "Quart", 0.5, true, function()
        Notification:Destroy()
    end)
end

local function GetFruit()
    local nearestFruit = nil
    local nearestDistance = math.huge
    local characterRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not characterRoot then
        return nil
    end

    for _, v in pairs(game.Workspace:GetChildren()) do
        if v:IsA("Tool") and (v.Name:find("Fruit") or v:FindFirstChild("Handle")) then
            local handle = v:FindFirstChild("Handle")
            if handle then
                local distance = (handle.Position - characterRoot.Position).Magnitude
                if distance < 50000 and distance < nearestDistance then
                    nearestDistance = distance
                    nearestFruit = v
                end
            end
        end
    end
    return nearestFruit
end

