-- ESP tables
local PlayerESPs = {}
local FruitESPs = {}

local MAX_DISTANCE = 50000

-- Create Player ESP
local function CreatePlayerESP(player)
    if PlayerESPs[player.Name] then return end
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local espGui = Instance.new("BillboardGui")
    espGui.Name = player.Name .. "_ESP"
    espGui.Adornee = hrp
    espGui.AlwaysOnTop = true
    espGui.Size = UDim2.new(0, 100, 0, 50)

    local nameLabel = Instance.new("TextLabel", espGui)
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    nameLabel.TextSize = 14
    nameLabel.Font = Enum.Font.GothamBold

    espGui.Parent = workspace
    PlayerESPs[player.Name] = espGui
end

local function RemovePlayerESP(player)
    if PlayerESPs[player.Name] then
        PlayerESPs[player.Name]:Destroy()
        PlayerESPs[player.Name] = nil
    end
end

-- Create Fruit ESP
local function CreateFruitESP(fruit)
    if FruitESPs[fruit] then return end
    local handle = fruit:FindFirstChild("Handle")
    if not handle then return end

    local espGui = Instance.new("BillboardGui")
    espGui.Name = "Fruit_" .. fruit.Name
    espGui.Adornee = handle
    espGui.AlwaysOnTop = true
    espGui.Size = UDim2.new(0, 100, 0, 50)

    local txt = Instance.new("TextLabel", espGui)
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.Text = fruit.Name
    txt.TextColor3 = Color3.fromRGB(255, 0, 0)
    txt.Font = Enum.Font.GothamBold
    txt.TextSize = 14

    espGui.Parent = workspace
    FruitESPs[fruit] = espGui
end

-- Main update loop
RunService.Heartbeat:Connect(function()
    -- Player ESP
    if Settings.PlayerESP then
        -- Remove old ESPs not in range
        for playerName, esp in pairs(PlayerESPs) do
            if not game.Players:FindFirstChild(playerName) then
                esp:Destroy()
                PlayerESPs[playerName] = nil
            end
        end
        -- Create/update ESPs
        for _, player in pairs(Players:GetPlayers()) do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player ~= LocalPlayer then
                local distance = (player.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if distance <= MAX_DISTANCE then
                    CreatePlayerESP(player)
                else
                    if PlayerESPs[player.Name] then
                        PlayerESPs[player.Name]:Destroy()
                        PlayerESPs[player.Name] = nil
                    end
                end
            end
        end
    end

    -- Fruit ESP
    if Settings.FruitESP then
        -- Create ESPs for nearby fruits
        for _, v in pairs(game.Workspace:GetChildren()) do
            if v:IsA("Tool") and (v.Name:find("Fruit") or v:FindFirstChild("Handle")) then
                local handle = v:FindFirstChild("Handle")
                if handle then
                    local distance = (handle.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                    if distance <= MAX_DISTANCE then
                        CreateFruitESP(v)
                    else
                        if FruitESPs[v] then
                            FruitESPs[v]:Destroy()
                            FruitESPs[v] = nil
                        end
                    end
                end
            end
        end
        -- Remove ESPs for fruits that no longer exist
        for fruit, esp in pairs(FruitESPs) do
            if not fruit.Parent or not fruit:FindFirstChild("Handle") then
                esp:Destroy()
                FruitESPs[fruit] = nil
            end
        end
    end
end)

